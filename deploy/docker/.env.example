# ─────────────────────────────────────────────────────────────────────────────
# dd-log-analyzer — Docker Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file and fill in your values:
#   cp .env.example .env

# Datadog API credentials
DD_API_KEY=your-datadog-api-key
DD_APP_KEY=your-datadog-app-key
DD_SITE=datadoghq.com

# Web dashboard authentication
WEB_USERNAME=admin
WEB_PASSWORD=changeme
WEB_SECRET_KEY=change-this-to-a-random-secret-key

# Slack notifications (optional — set WATCH_SLACK=true to enable)
SLACK_WEBHOOK_URL=

# Jira integration (optional — set WATCH_JIRA=true to enable)
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
